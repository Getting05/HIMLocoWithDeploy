<!-- Launch file for RViz visualization of Mybot quadruped robot (ROS1 Noetic)

Starts:
  1. robot_state_publisher  - loads URDF and publishes TF from /joint_states
  2. joint_state_publisher  - publishes default joint states (standing pose)
  3. rviz                   - 3D visualization with pre-configured display

Usage (standalone, robot in default standing pose):
  roslaunch deploy_cpp visualize.launch

Usage (with deploy node, real joint states):
  roslaunch deploy_cpp visualize.launch use_jsp:=false
  roslaunch deploy_cpp deploy.launch debug_no_motor:=true
-->
<launch>
    <arg name="use_jsp" default="true"
         doc="Start joint_state_publisher (false when using deploy_node)" />

    <!-- Load URDF -->
    <param name="robot_description"
           textfile="$(find deploy_cpp)/robot/mybot_v2/urdf/mybot_v2.urdf" />

    <!-- Robot State Publisher: reads URDF, subscribes to /joint_states,
         publishes TF transforms for all links -->
    <node pkg="robot_state_publisher" type="robot_state_publisher"
          name="robot_state_publisher" output="screen" />

    <!-- Joint State Publisher (static default pose) -->
    <node pkg="joint_state_publisher" type="joint_state_publisher"
          name="joint_state_publisher" output="screen"
          if="$(arg use_jsp)">
        <rosparam param="zeros">
            FR_hip_joint: -0.1
            FR_thigh_joint: 0.67
            FR_calf_joint: -1.3
            FL_hip_joint: 0.1
            FL_thigh_joint: 0.67
            FL_calf_joint: -1.3
            RR_hip_joint: -0.1
            RR_thigh_joint: 0.67
            RR_calf_joint: -1.3
            RL_hip_joint: 0.1
            RL_thigh_joint: 0.67
            RL_calf_joint: -1.3
        </rosparam>
    </node>

    <!-- RViz -->
    <node pkg="rviz" type="rviz" name="rviz" output="screen"
          args="-d $(find deploy_cpp)/config/mybot_v2.rviz" />
</launch>
